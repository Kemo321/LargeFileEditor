# --- System ---
.DS_Store
Thumbs.db

# --- Compilation and Build (CMake) ---
# Ignore any build folder regardless of name (build, debug, release)
[Bb]uild/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.cmake
install/

# --- Executables and Libraries (Binaries) ---
*.exe
*.out
*.app
*.so
*.a
*.lib
*.dll
*.dylib

# --- Qt Specific ---
# Files automatically generated by Qt tools (moc, uic, rcc)
# If you use CMake these files end up in the build folder, but just in case:
moc_*.cpp
ui_*.h
qrc_*.cpp
*.qmlc
*.jsc

# --- IDE junk ---
# Qt Creator
*.user
*.user.*
*.creator
*.files
*.includes
*.config

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# CLion / JetBrains
.idea/
cmake-build-*/

# Visual Studio
.vs/
*.sln
*.vcxproj
*.filters

# --- Submodules ---
# We do not ignore the extern/ folder itself because it contains submodule definitions,
# but make sure the submodule files themselves are managed via git submodule.

# --- Documentation ---
# If you generate Doxygen locally:
/doc/html/
/doc/latex/

# --- Other ---
*.log
*.tmp
*.bak

# --- Coverage (LCOV) ---
build-coverage/
*.info
*.gcda
*.gcno
coverage.css
coverage.functions.html
coverage.html
coverage.js

*.py
.venv/

bigfile.txt
